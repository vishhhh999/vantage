VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_RIOT_API_KEY=your_riot_api_key
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Riot Sign-On (RSO) ---
# These come from Riot AFTER they provision an RSO client for your app via
# the developer portal Messages tab (this is a manual step on Riot's side,
# not self-service). Until these are set, RSO sign-in is disabled and the
# dashboard falls back to manual Riot ID entry (which cannot fetch match
# data, since Riot requires RSO consent for that).

# Public — safe to expose to the browser, used to build the Riot login URL.
VITE_RIOT_CLIENT_ID=your_riot_client_id
VITE_RIOT_REDIRECT_URI=https://your-domain.vercel.app/riot-callback

# Secret — server-only, NEVER prefix with VITE_ or it will ship to the browser.
# Used only inside /api/riot-token.js.
RIOT_CLIENT_ID=your_riot_client_id
RIOT_CLIENT_SECRET=your_riot_client_secret
RIOT_REDIRECT_URI=https://your-domain.vercel.app/riot-callback
